{
  "name": "ace-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:emulators": "NEXT_PUBLIC_FIREBASE_USE_EMULATORS=1 FIREBASE_USE_EMULATORS=1 FIREBASE_EMULATOR_PROJECT_ID=demo-ace-website GCLOUD_PROJECT=demo-ace-website FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199 NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099 NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199 next dev --webpack --hostname 127.0.0.1 --port 3004",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "ops:auth-report": "node --import tsx scripts/report-auth-failures.ts",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:smoke": "npx playwright test tests/auth-smoke.spec.ts",
    "validate:firebase": "node --import tsx scripts/verify-firebase.ts",
    "validate:firebase:project": "node --import tsx scripts/validate-firebase-production.ts",
    "emulators:start": "firebase emulators:start --project demo-ace-website",
    "emulators:exec:auth": "firebase emulators:exec --only auth,firestore --project demo-ace-website"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.4.0",
    "react-hook-form": "^7.71.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "firebase-tools": "^15.11.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.7",
    "flatted": "^3.4.1",
    "minimatch": "3.1.4",
    "eslint": {
      "ajv": "6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "6.14.0"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.9"
    }
  }
}
